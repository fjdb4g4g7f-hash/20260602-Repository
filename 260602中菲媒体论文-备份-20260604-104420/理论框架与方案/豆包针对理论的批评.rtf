\uc0\u36825 \u26679 \u19968 \u26469 \u65292 \u27599 \u20010 \u29702 \u35770 \u37117 \u26377 \u33258 \u24049 \u26126 \u30830 \u30340 \u20301 \u32622 \u21644 \u21151 \u33021 \u65292 \u27809 \u26377 \u37325 \u21472 \u65292 \u27809 \u26377 \u30683 \u30462 \u65292 \u25152 \u26377 \u29702 \u35770 \u37117 \u26381 \u21153 \u20110 \u21516 \u19968 \u20010 \u26680 \u24515 \u30740 \u31350 \u38382 \u39064 \u65306 **\u20013 \u33778 \u23186 \u20307 \u22914 \u20309 \u36890 \u36807 \u19981 \u21516 \u30340 \u35805 \u35821 \u31574 \u30053 \u65292 \u22312 \u35758 \u39064 \u12289 \u36523 \u20221 \u12289 \u31995 \u32479 \u19977 \u20010 \u32500 \u24230 \u19978 \u24314 \u26500 \u23545 \u31435 \u30340 \u23041 \u32961 \u21465 \u20107 \u65292 \u24182 \u36890 \u36807 \u21465 \u20107 \u31454 \u20105 \u23454 \u29616 \u26435 \u21147 \u30340 \u30446 \u30340 \u65311 **\
