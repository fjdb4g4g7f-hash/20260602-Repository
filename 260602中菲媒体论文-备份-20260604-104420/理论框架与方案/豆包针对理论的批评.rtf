\uc0\u35745 \u31639 \u35805 \u35821 \u20998 \u26512 \u26041 \u27861 \u22312 \u22269 \u38469 \u25919 \u27835 \u35821 \u35328 \u23398 \u30740 \u31350 \u20013 \u30340 \u24212 \u29992 \u12289 \u20248 \u21183 \u21644 \u23616 \u38480 \u24615 \u65292 \u22905 \u27809 \u25552 \u21834 \u65292 \u20320 \u20174 \u21738 \u30475 \u30340 \u65292 \u20320 \u26159 \u35748 \u30495 \u22312 \u20998 \u26512 \u30340 \u21527 \u65311 \
