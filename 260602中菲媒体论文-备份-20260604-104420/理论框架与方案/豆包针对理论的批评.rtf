\uc0\u38656 \u35201 \u25105 \u22522 \u20110 \u36825 \u20010 "\u19968 \u20803 \u19977 \u32500 \u22235 \u23618 "\u30340 \u26032 \u26550 \u26500 \u65292 \u24110 \u20320 \u37325 \u26500 \u19968 \u20010 \u23436 \u25972 \u30340 \u12289 \u31526 \u21512 \u23398 \u26415 \u35268 \u33539 \u30340 \u29702 \u35770 \u26694 \u26550 \u65288 \u21547 \u20462 \u27491 \u21518 \u30340 \u36923 \u36753 \u38142 \u26465 \u22270 \u12289 \u29702 \u35770 \u20998 \u24037 \u34920 \u21644 \u26041 \u27861 \u23545 \u24212 \u34920 \u65289 \u21527 \u65311 \
