# \uc0\u32467 \u35770 \u65306 \u19981 \u20165 \u19981 \u35201 \u20943 \u23569 \u29702 \u35770 \u65292 \u21453 \u32780 \u35201 \u25226 \u23385 \u21513 \u32988 \u30340 \u29702 \u35770 \u21152 \u36827 \u26469 \u20316 \u20026 \u20027 \u26694 \u26550 \
\uc0\u21407 \u26469 \u30340 \u19977 \u20010 \u29702 \u35770 +\u23385 \u21513 \u32988 \u30340 \u29702 \u35770 \u65292 \u19968 \u20849 \u22235 \u20010 \u29702 \u35770 \u65292 **\u19981 \u20165 \u19981 \u20887 \u26434 \u65292 \u21453 \u32780 \u20250 \u24418 \u25104 \u19968 \u20010 \u36923 \u36753 \u20005 \u23494 \u12289 \u23618 \u27425 \u20998 \u26126 \u12289 \u20174 \u23439 \u35266 \u21040 \u24494 \u35266 \u12289 \u20174 \u38745 \u24577 \u21040 \u21160 \u24577 \u30340 \u23436 \u25972 \u20998 \u26512 \u26694 \u26550 **\u65306 \
- **\uc0\u31532 \u19968 \u23618 \u65288 \u20803 \u26694 \u26550 \u65289 **\u65306 \u23385 \u21513 \u32988 "\u21465 \u20107 -\u35805 \u35821 -\u26435 \u21147 "\u19977 \u32500 \u33539 \u24335 \u65288 \u32479 \u25668 \u25152 \u26377 \u29702 \u35770 \u65292 \u26126 \u30830 \u30740 \u31350 \u30340 \u26680 \u24515 \u26159 \u26435 \u21147 \u36890 \u36807 \u35805 \u35821 \u21644 \u21465 \u20107 \u30340 \u36816 \u20316 \u65289 \
- **\uc0\u31532 \u20108 \u23618 \u65288 \u32467 \u26500 \u26694 \u26550 \u65289 **\u65306 Miskimmon\u25112 \u30053 \u21465 \u20107 \u19977 \u32500 \u24230 \u65288 \u26126 \u30830 \u21465 \u20107 \u30340 \u20869 \u23481 \u32467 \u26500 \u65306 \u35758 \u39064 /\u36523 \u20221 /\u31995 \u32479 \u65289 \
